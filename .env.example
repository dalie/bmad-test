# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# Server Configuration
PORT=3000

# Host Media Paths (where your media lives on the host machine)
MOVIES_HOST_PATH=~/media/movies
TV_HOST_PATH=~/media/tv
OTHER_HOST_PATH=~/media/other

# Media Source Paths (mapped to Docker volumes in compose — container-internal, rarely changed)
MEDIA_MOVIES_PATH=/mnt/media/movies
MEDIA_TV_PATH=/mnt/media/tv
# Other media (home videos, recordings, etc.) — skips TMDB matching
MEDIA_OTHER_PATH=/mnt/media/other

# System Cache / Artifact Storage Path
CACHE_PATH=/mnt/cache

# Admin Access
# Set to your LAN subnet for admin access (required for Docker deployments)
# ADMIN_SUBNET=192.168.1.0/24

# Set to true if running behind a reverse proxy
# TRUST_PROXY=true
