# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# Server Configuration
PORT=3000

# Media Source Paths (local dev only — overridden inside Docker container by docker-compose.yml)
MEDIA_MOVIES_PATH=./_media/movies
MEDIA_TV_PATH=./_media/tv
# Other media (home videos, recordings, etc.) — skips TMDB matching
MEDIA_OTHER_PATH=./_media/other

# System Cache / Artifact Storage Path (local dev only — overridden to /mnt/cache inside Docker)
CACHE_PATH=./data

# Host Media Paths (Docker only — where your media lives on the host machine)
# These set the left side of volume mounts in docker-compose.yml
MOVIES_HOST_PATH=~/media/movies
TV_HOST_PATH=~/media/tv
OTHER_HOST_PATH=~/media/other

# Admin Access
# Set to your LAN subnet for admin access (required for Docker deployments)
# ADMIN_SUBNET=192.168.1.0/24

# Set to true if running behind a reverse proxy
# TRUST_PROXY=true
